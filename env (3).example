# ── Nuevas variables de Admin y Piloto ─────────────────────────────

# Clave para entrar al panel /admin — solo tú la sabes
# Ponla en Vercel → Environment Variables
# Ej: VITE_ADMIN_KEY=lumajira2024admin
VITE_ADMIN_KEY=

# Contraseña por defecto para agricultores creados desde el admin
# Cuando creas un usuario manualmente y no le asignas contraseña
# usa esta. El agricultor puede cambiarla después.
# Ej: VITE_PILOT_DEFAULT_PASS=agrilux2024
VITE_PILOT_DEFAULT_PASS=agrilux2024

# Google Drive (para exportar dataset)
VITE_GOOGLE_CLIENT_ID=

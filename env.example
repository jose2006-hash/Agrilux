# ═══════════════════════════════════════════════════════════════
# AGRILUX — Variables de entorno
# Copia este archivo como .env y completa tus claves
# NUNCA subas .env a GitHub (ya está en .gitignore)
# ═══════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────
# IA PRINCIPAL — Análisis de imágenes y diagnóstico
# ──────────────────────────────────────────────────────────────

# OpenRouter (acceso a Gemini 2.0 Flash, DeepSeek-VL, Llama 4)
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Gemini directo (opcional, backup)
# Obtener en: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
GEMINI_API_KEY=

# DeepSeek (chat y texto — más económico que GPT)
# Obtener en: https://platform.deepseek.com
VITE_DEEPSEEK_API_KEY=
DEEPSEEK_API_KEY=


# ──────────────────────────────────────────────────────────────
# DIAGNÓSTICO VISUAL DE PLANTAS
# ──────────────────────────────────────────────────────────────

# Crop.health de kindwise — PRIMERA OPCIÓN (base de datos EPPO)
# Especializado en cultivos comerciales: papa, palta, arándano
# Registro gratis: https://crop.kindwise.com
# Plan free: 100 identificaciones/mes
CROP_HEALTH_API_KEY=

# Plant.id — fallback generalista
# Registro: https://plant.id
# Plan free: 100 req/día
PLANT_ID_API_KEY=

# HuggingFace — fallback gratuito (opcional)
# Registro: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=


# ──────────────────────────────────────────────────────────────
# CLIMA
# ──────────────────────────────────────────────────────────────

# AgroMonitoring (clima + satélite agrícola)
# Registro: https://agromonitoring.com
AGROMONITORING_API_KEY=

# OpenWeatherMap (opcional — si no está, usa Open-Meteo gratis)
# Registro: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Open-Meteo: 100% gratuito, sin key, ya integrado como fallback ✅


# ──────────────────────────────────────────────────────────────
# SATÉLITE & SUELO (nuevas integraciones)
# ──────────────────────────────────────────────────────────────

# Sentinel Hub — imágenes NDVI Sentinel-2 (ESA, gratis para investigación)
# Registro: https://dataspace.copernicus.eu/
# Crear OAuth App en: https://shapps.dataspace.copernicus.eu/dashboard/#/account/settings
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=

# NASA EarthData — alertas FIRMS de incendios y anomalías (totalmente gratuito)
# Registro: https://urs.earthdata.nasa.gov/users/new
# Generar key: https://api.nasa.gov (sección "Generate API Key")
NASA_EARTHDATA_KEY=

# SoilGrids ISRIC — datos de suelo pH, carbono, textura (100% gratuito, sin key)
# No requiere registro ✅


# ──────────────────────────────────────────────────────────────
# COMUNICACIÓN — WhatsApp al agricultor
# ──────────────────────────────────────────────────────────────

# Twilio — WhatsApp Business API
# Registro: https://www.twilio.com/try-twilio
# En desarrollo: usar Sandbox (+14155238886), agricultores envían "join <palabra>" primero
# En producción: activar WhatsApp Business y aprobar plantillas en Meta
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Formato: whatsapp:+14155238886 (sandbox) o whatsapp:+51XXXXXXXXX (producción)
TWILIO_WHATSAPP_FROM=


# ──────────────────────────────────────────────────────────────
# MAPAS & GEOLOCALIZACIÓN
# ──────────────────────────────────────────────────────────────

# Mapbox — mapas de calor de plagas y mapa estático de parcelas
# Registro: https://account.mapbox.com
# Plan free: 50.000 requests/mes
# ⚠️  Este token ES público por diseño de Mapbox (va al frontend)
VITE_MAPBOX_TOKEN=


# ──────────────────────────────────────────────────────────────
# PAGOS — Marketplace de insumos
# ──────────────────────────────────────────────────────────────

# Culqi — pasarela peruana (Yape, Plin, tarjetas)
# Registro: https://culqi.com
# VITE_ = pública (frontend), sin VITE_ = privada (backend)
VITE_CULQI_PUBLIC_KEY=
CULQI_SECRET_KEY=

# Mercado Pago — alternativa LATAM
# Registro: https://www.mercadopago.com.pe/developers
VITE_MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=


# ──────────────────────────────────────────────────────────────
# FIREBASE — Base de datos y auth
# ──────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
